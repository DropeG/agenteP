# Canvas UC API Configuration
CANVAS_API_URL=https://canvas.uc.cl
CANVAS_API_TOKEN=your_canvas_token_here

# LLM Providers Configuration (Optional - Bypassed by default)
# The local worker loops tasks into agents/io/ and uses Antigravity (AI Assistant)
# as the execution engine for free, zero-cost operations.
# Add these keys ONLY if you want to use standalone cloud LLM agents.
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration (Defaults to local SQLite)
DATABASE_URL=sqlite:///./database.db
